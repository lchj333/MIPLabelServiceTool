<Window
    x:Class="MIPLabelServiceTool.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MIP CAD Test"
    Height="720"
    Width="900"
    Background="#F3F4F6">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#4B5563"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- 0. Drag & Drop Area -->
            <RowDefinition Height="150"/>
            <!-- 1. Input Path -->
            <RowDefinition Height="Auto"/>
            <!-- 2. MIP Label Info display -->
            <RowDefinition Height="110"/>
            <!-- 3. Remove Label Button -->
            <RowDefinition Height="Auto"/>
            <!-- 4. Input Label Name or Guid -->
            <RowDefinition Height="Auto"/>
            <!-- 5. Apply Label Button -->
            <RowDefinition Height="Auto"/>
            <!-- 6. Output Path -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag & Drop Border -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,15"
            BorderThickness="2"
            BorderBrush="#9CA3AF"
            Background="#F9FAFB"
            CornerRadius="8"
            AllowDrop="True"
            Drop="DropArea_Drop"
            DragEnter="DropArea_DragEnter">
            
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="#4B5563"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#1F2937"
                    HorizontalAlignment="Center"
                    Text="Drag &amp;&amp; Drop"/>
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="12"
                    Foreground="#6B7280"
                    HorizontalAlignment="Center"
                    Text="CAD File"/>
            </StackPanel>
        </Border>

        <!-- Input Path Grid -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Input" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
            <TextBox x:Name="txtInput" Grid.Column="1" IsReadOnly="True" Background="#F3F4F6" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- MIP Label Display (Read-Only) -->
        <TextBox
            x:Name="txtFileInfo"
            Grid.Row="2"
            Margin="0,0,0,15"
            Height="95"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto"
            Background="#FFFFFF"
            BorderBrush="#D1D5DB"
            Padding="12,10"
            FontSize="13"
            FontFamily="Consolas, Malgun Gothic"
            Text="파일을 드래그&amp;드랍하여 정보를 확인하세요."/>

        <!-- Remove Label Area -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button
                x:Name="btnRemoveLabel"
                Grid.Column="0"
                Content="Remove Label"
                Click="Remove_Click"
                Width="150"
                HorizontalAlignment="Left"
                Background="#EF4444"
                Foreground="White"/>
        </Grid>

        <!-- Target Label Input Grid -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" VerticalAlignment="Center">
                <Run Text="Input Label"/>
                <LineBreak/>
                <Run Text="Name Or Guid"/>
            </TextBlock>
            <TextBox x:Name="txtLabelInfo" Grid.Column="1" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Apply Label Area -->
        <Grid Grid.Row="5" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button
                x:Name="btnApplyLabel"
                Grid.Column="0"
                Content="Apply Label"
                Click="Apply_Click"
                Width="150"
                HorizontalAlignment="Left"
                Background="#3B82F6"
                Foreground="White"/>
        </Grid>

        <!-- Output Path Grid -->
        <Grid Grid.Row="6" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Output" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
            <TextBox x:Name="txtOutput" Grid.Column="1" IsReadOnly="True" Background="#F3F4F6" VerticalContentAlignment="Center"/>
        </Grid>

    </Grid>
</Window>